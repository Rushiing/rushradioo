# 在 Notion 集成中创建内部集成，复制 Secret：https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Blog：数据库 ID（页面 URL 中 32 位十六进制，可带或不带连字符）
NOTION_BLOG_DATABASE_ID=

# Feeds：另一个数据库 ID（瀑布流卡片）
NOTION_FEEDS_DATABASE_ID=

# 可选：仅同步「状态」为 Published 的文章（属性名与选项名需与 Notion 中一致）
# NOTION_BLOG_STATUS_PROPERTY=Status
# NOTION_BLOG_STATUS_VALUE=Published
